### Milestone 3: Branch-Only Work Coordination
Build the core engine bottleneck: serialize write-access to the repository working directory, execute pre-commit testing under lock boundaries, and handle merge exceptions gracefully.

#### 6.1 Lock Architecture
The checkout lock is represented by a **Redis Redlock** instance on the key `repo:lock:global`.

```text
EditIntents Received
         |
         v
+--------+--------+
| Queue Manager   | ---> Serializes requests per branch
+--------+--------+
         |
         v
+--------+--------+
| Redlock Acquire | ---> Mutex lock obtained for 30s
+--------+--------+
         |
         v
+--------+--------+
| Git Checkout    | ---> git checkout feature/auth-architect-2
+--------+--------+
         |
         v
+--------+--------+
| File Writes     | ---> applyEditBatch()
+--------+--------+
         |
         v
+--------+--------+
| Exec Validation | ---> npm run lint && npm run test (for touched paths only)
+--------+--------+
         |
         +--------------------------+
         | (PASSED)                 | (FAILED)
         v                          v
+--------+--------+        +--------+--------+
| Git Commit/Push |        | Git Reset --hard| ---> Rollback edit
+--------+--------+        +--------+--------+
         |                          |
         +------------+-------------+
                      |
                      v
+--------+--------+
| Redlock Release |
+--------+--------+
```

#### 6.2 Code Snippet: Work Coordinator in `orchestrator/edit-coordinator/src/applier.ts`
```typescript
import simpleGit from 'simple-git';
import { createClient } from 'redis';
import Redlock from 'redlock';
import fs from 'fs/promises';
import { execa } from 'execa';

const redis = createClient({ url: process.env.REDIS_URL });
const redlock = new Redlock([redis], { retryCount: 10, retryDelay: 500 });
const git = simpleGit({ baseDir: process.env.REPO_ROOT });

export async function applyEditBatch(intents: any[]) {
  const { branch, featureSlug, agentId, traceId } = intents[0];
  const resource = `locks:repo:global`; // Single-writer global repository lock
  const leaseTtl = 45000; // 45s maximum lease window to account for test suites

  const lock = await redlock.acquire([resource], leaseTtl);
  try {
    // 1. Checkout targeted agent branch
    await git.checkout(branch);

    // 2. Apply batch file edits
    for (const intent of intents) {
      const { path, op, content } = intent.payload;
      const absPath = `${process.env.REPO_ROOT}/${path}`;

      if (op === 'delete') {
        await fs.rm(absPath, { force: true });
        await git.rm([path]);
      } else if (op === 'add' || op === 'replace' || op === 'progress') {
        await fs.writeFile(absPath, content || '', 'utf8');
        await git.add([path]);
      }
    }

    // 3. Pre-Commit Validation: Run tests for touched paths (Throwaway worktree used for isolation)
    const testResult = await runWorktreeValidation(branch, intents.map(i => i.payload.path));
    if (!testResult.passed) {
      await git.reset(['--hard']); // Rollback dirty working index
      throw new Error(`Pre-commit validation rejected edits: ${testResult.error}`);
    }

    // 4. Commit and Push
    const commitMsg = `feat(${featureSlug}): agent ${agentId} batch update [${traceId}]`;
    await git.commit(commitMsg);
    await git.push('origin', branch);

    // 5. Emit EditApplied
    return { commitSha: (await git.revparse(['HEAD'])).trim() };

  } finally {
    await lock.release();
  }
}

// Validation run on isolated throwaway worktree to prevent stalling core working copy
async function runWorktreeValidation(branch: string, paths: string[]) {
  const worktreePath = `/tmp/scratch-${crypto.randomUUID()}`;
  try {
    await git.writeSystem('worktree', ['add', '--detach', worktreePath, branch]);
    
    // Run lint in scratch workspace
    await execa('npm', ['run', 'lint', '--', ...paths], { cwd: worktreePath });
    
    // Run related unit tests only
    await execa('npm', ['test', '--', '--findRelatedTests', ...paths], { cwd: worktreePath });
    
    return { passed: true };
  } catch (err: any) {
    return { passed: false, error: err.stderr || err.message };
  } finally {
    await execa('rm', ['-rf', worktreePath]);
    await git.writeSystem('worktree', ['prune']);
  }
}
```

