#### 7.1 Lifecycle Transition Engine (`services/lifecycle-management`)
```typescript
import { createClient } from 'redis';
import { BusClient } from '@team1/bus-client';

const bus = new BusClient();

export async function evaluateGateCheck(featureSlug: string, currentPhase: number, artifactCompleted: boolean) {
  // Query health-monitoring for MBO metric status
  const mboStatus = await queryMboMetrics(featureSlug, currentPhase);

  const bothPassed = artifactCompleted && mboStatus.ok;
  const gapDeclared = mboStatus.gapDeclared; // Path (c) - routine gap declaration

  if (bothPassed || gapDeclared) {
    // Advance Phase
    await updatePhaseDatabase(featureSlug, currentPhase + 1);
    await bus.publish('intents:phase-gate-check', {
      type: 'PhaseGateCheck',
      payload: { featureSlug, phase: currentPhase + 1, status: 'advanced' },
      ts: Date.now(),
      traceId: crypto.randomUUID(),
      featureSlug,
      branch: '',
      source: 'lifecycle-management',
      idempotencyKey: crypto.randomUUID()
    });
  } else {
    // Fail MBO Gate - Trigger Backtrack/Backward Intent
    const backtrackPhase = resolveBackwardPhase(currentPhase);
    await updatePhaseDatabase(featureSlug, backtrackPhase);
    
    await bus.publish('intents:phase-gate-check', {
      type: 'PhaseGateCheck',
      payload: { featureSlug, phase: backtrackPhase, status: 'backtrack', reason: mboStatus.reason },
      ts: Date.now(),
      traceId: crypto.randomUUID(),
      featureSlug,
      branch: '',
      source: 'lifecycle-management',
      idempotencyKey: crypto.randomUUID()
    });
  }
}

function resolveBackwardPhase(currentPhase: number): number {
  const map: Record<number, number> = {
    1: 1, // Planning
    2: 1, // Architecture -> Planning
    3: 2, // Implementation -> Architecture
    4: 3, // Testing -> Implementation
    5: 3, // Deployment -> Implementation
    6: 3, // Monitoring -> Implementation
    7: 6  // Analysis -> Monitoring
  };
  return map[currentPhase] || 1;
}
```

