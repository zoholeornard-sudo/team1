#### 4.3 Code Snippet: `packages/bus-client/src/index.ts`
```typescript
import { createClient, RedisClientType } from 'redis';
import Ajv from 'ajv';

export class BusClient {
  private redis: RedisClientType;
  private ajv = new Ajv();

  constructor(private url = process.env.REDIS_URL || 'redis://localhost:6379') {
    this.redis = createClient({ url: this.url });
  }

  async connect() {
    await this.redis.connect();
  }

  async publish(stream: string, envelope: any) {
    // Enforce 24-hour deduplication guard
    const dedupKey = `idempotency:${envelope.idempotencyKey}`;
    const acquired = await this.redis.set(dedupKey, "1", { NX: true, EX: 86400 });
    if (!acquired) {
      console.warn(`Duplicate intent dropped: ${envelope.idempotencyKey}`);
      return;
    }

    // Publish to stream
    await this.redis.xAdd(stream, '*', {
      type: envelope.type,
      envelope: JSON.stringify(envelope)
    });
  }

  async subscribe(stream: string, group: string, consumer: string, handler: (data: any) => Promise<void>) {
    try {
      await this.redis.xGroupCreate(stream, group, '0', { MKSTREAM: true });
    } catch (e) {
      // Group already exists, ignore
    }

    while (true) {
      const streams = await this.redis.xReadGroup(group, consumer, [{ key: stream, id: '>' }], { COUNT: 1, BLOCK: 2000 });
      if (!streams) continue;

      for (const streamEntry of streams) {
        for (const message of streamEntry.messages) {
          const envelope = JSON.parse(message.message.envelope);
          try {
            await handler(envelope);
            await this.redis.xAck(streamEntry.key, group, message.id);
          } catch (err) {
            console.error(`Stream message handler execution failed: ${message.id}`, err);
            // Re-route to Dead-Letter Stream after 3 retries (stored in stream-specific retry count hash)
            await this.handleFailure(streamEntry.key, message, group);
          }
        }
      }
    }
  }

  private async handleFailure(stream: string, message: any, group: string) {
    const retryKey = `retry:${group}:${message.id}`;
    const retries = await this.redis.incr(retryKey);
    await this.redis.expire(retryKey, 3600);

    if (retries > 3) {
      await this.redis.xAdd('intents:dead-letter', '*', {
        originalStream: stream,
        messageId: message.id,
        payload: message.message.envelope,
        reason: 'Max retries exceeded'
      });
      await this.redis.xAck(stream, group, message.id);
      await this.redis.del(retryKey);
      console.error(`Message ${message.id} moved to dead-letter stream.`);
    }
  }
}
```

