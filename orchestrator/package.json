{
  "name": "team1-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*",
    "runtime",
    "agent-registry",
    "orchestrator-api"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "build": "bun --filter '*' build",
    "test": "bun --filter '*' test",
    "boot:bus": "docker compose -f infra/docker-compose.yml up -d redis",
    "boot:services": "bun --filter './services/*' dev",
    "lint": "bun --filter '*' lint"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/redis": "^4.0.11",
    "execa": "^9.6.1",
    "redis": "^6.0.1",
    "typescript": "^5"
  }
}
